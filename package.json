{
  "name": "meteoagricole2mqtt",
  "version": "1.0.0",
  "description": "Scrape lameteoagricole.net and publish to MQTT with Home Assistant discovery",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js -m $MQTT_URI --locations $LOCATIONS -l DEBUG --scan-interval 300 --city-delay 30",
    "start:dev": "node --inspect=0.0.0.0:9229 dist/index.js -m $MQTT_URI --locations $LOCATIONS -l DEBUG --scan-interval 300 --city-delay 30",
    "watch": "tsc-watch --onSuccess \"npm run start:dev\"",
    "test": "jest"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node-fetch": "^2.6.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsc-watch": "^6.2.1",
    "typescript": "5.4"
  },
  "dependencies": {
    "@types/node": "^22.13.1",
    "cheerio": "^1.0.0",
    "minimist": "^1.2.8",
    "mqtt": "^5.10.3",
    "node-fetch": "^2.7.0"
  }
}
